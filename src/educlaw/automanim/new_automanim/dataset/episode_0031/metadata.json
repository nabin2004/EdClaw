        \n        # Arrows from formula to pe\n        formula_to_pe = Arrow(\n            formula_group.get_right(),\n            pos_encodings.get_left() + LEFT * 0.3,\n            buff=0.2,\n            stroke_width=2,\n            color=\"#FF6B6B\",\n            max_stroke_width_to_length_ratio=10,\n            max_tip_length_to_length_ratio=0.3\n        )\n        \n        pe_arrows = VGroup(*[\n            Arrow(\n                emb.get_right(),\n                pe.get_left(),\n                buff=0.1,\n                stroke_width=2,\n                color=\"#FFE66D\"\n            ) for emb, pe in zip(embeddings, pos_encodings)\n        ])\n        \n        self.play(\n            FadeIn(pe_title),\n            GrowArrow(formula_to_pe),\n            run_time=0.7\n        )\n        self.play(\n            *[GrowArrow(a) for a in pe_arrows],\n            run_time=0.5\n        )\n        self.play(\n            *[FadeIn(pe) for pe in pos_encodings],\n            run_time=1\n        )\n        self.wait(1)\n        \n        # ============================================\n        # PART 7: Element-wise Addition (23-27s)\n        # ============================================\n        # Show addition operation\n        plus_signs = VGroup(*[\n            MathTex(r\"+\", font_size=36, color=\"#FFFFFF\").move_to(\n                (emb.get_right() + pe.get_left()) / 2\n            ) for emb, pe in zip(embeddings, pos_encodings)\n        ])\n        \n        self.play(\n            *[FadeIn(p) for p in plus_signs],\n            run_time=0.5\n        )\n        \n        # Create final combined embeddings\n        final_embeddings = VGroup(\n            create_embedding(dims, \"#96CEB4\"),\n            create_embedding(dims, \"#96CEB4\"),\n            create_embedding(dims, \"#96CEB4\"),\n        )\n        \n        for i, (final, pe) in enumerate(zip(final_embeddings, pos_encodings)):\n            final.move_to(pe.get_right() + RIGHT * 1.2)\n        \n        final_title = Text(\"Final Embeddings\", font_size=18, color=\"#96CEB4\")\n        final_title.next_to(final_embeddings, DOWN, buff=0.4)\n        \n        equal_signs = VGroup(*[\n            MathTex(r\"=\", font_size=36, color=\"#FFFFFF\").move_to(\n                (pe.get_right() + final.get_left()) / 2\n            ) for pe, final in zip(pos_encodings, final_embeddings)\n        ])\n        \n        self.play(\n            FadeIn(final_title),\n            *[FadeIn(e) for e in equal_signs],\n            run_time=0.5\n        )\n        \n        # Show the addition happening\n        for i, (emb, pe, final) in enumerate(zip(embeddings, pos_encodings, final_embeddings)):\n            # Create a visual effect showing the blend\n            src_emb = emb.copy()\n            src_pe = pe.copy()\n            \n            self.play(\n                src_emb.animate.move_to(final.get_center()).set_opacity(0.5),\n                src_pe.animate.move_to(final.get_center()).set_opacity(0.5),\n                FadeIn(final),\n                run_time=0.3\n            )\n            self.remove(src_emb, src_pe)\n        \n        self.wait(1)\n        \n        # ============================================\n        # PART 8: Summary (27-30s)\n        # ============================================\n        # Fade out most elements and show summary\n        all_elements = [\n            title, subtitle, input_title, tokens, token_labels,\n            embedding_title, *embeddings, *embed_arrows,\n            pe_title, *pos_encodings, *pe_arrows, formula_to_pe,\n            formula_group, pe_title, wave_title, axes, waves,\n            *plus_signs, *equal_signs, final_title\n        ]\n        \n        summary = Text(\n            \"Positional Encoding: Position-aware token representations\",\n            font_size=28,\n            color=\"#FFFFFF\"\n        ).move_to(ORIGIN)\n        \n        summary2 = Text(\n            \"Unique sinusoidal pattern for each position\",\n    