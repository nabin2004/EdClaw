 0%|          | 0/5 [00:00<?, ?it/s]\r                                                                                                    \r\rAnimation 25: FadeOut(Text('Transformer Positional Encoding')), etc.:   0%|          | 0/15 [00:00<?, ?it/s]\rAnimation 25: FadeOut(Text('Transformer Positional Encoding')), etc.:  13%|█▎        | 2/15 [00:00<00:00, 15.02it/s]\rAnimation 25: FadeOut(Text('Transformer Positional Encoding')), etc.:  27%|██▋       | 4/15 [00:00<00:00, 14.80it/s]\rAnimation 25: FadeOut(Text('Transformer Positional Encoding')), etc.:  40%|████      | 6/15 [00:00<00:00, 14.72it/s]\rAnimation 25: FadeOut(Text('Transformer Positional Encoding')), etc.:  53%|█████▎    | 8/15 [00:00<00:00, 14.55it/s]\rAnimation 25: FadeOut(Text('Transformer Positional Encoding')), etc.:  67%|██████▋   | 10/15 [00:00<00:00, 14.34it/s]\rAnimation 25: FadeOut(Text('Transformer Positional Encoding')), etc.:  80%|████████  | 12/15 [00:00<00:00, 14.14it/s]\rAnimation 25: FadeOut(Text('Transformer Positional Encoding')), etc.:  93%|█████████▎| 14/15 [00:00<00:00, 14.07it/s]\r                                                                                                                     \r\rAnimation 26: FadeIn(Text('Unique sinusoidal pattern for each position')):   0%|          | 0/8 [00:00<?, ?it/s]\r                                                                                                                \r\rAnimation 28: FadeOut(Text('Positional Encoding: Position-aware token representations')), etc.:   0%|          | 0/8 [00:00<?, ?it/s]\rAnimation 28: FadeOut(Text('Positional Encoding: Position-aware token representations')), etc.:  75%|███████▌  | 6/8 [00:00<00:00, 49.73it/s]\r                                                                                                                                             \r"
