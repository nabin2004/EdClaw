 input_title = Text(\"Input Tokens\", font_size=18, color=\"#888888\").next_to(tokens, UP, buff=0.4)\n        \n        self.play(\n            FadeIn(input_title),\n            *[FadeIn(t) for t in tokens],\n            run_time=1\n        )\n        self.wait(0.5)\n        self.play(\n            *[FadeIn(l) for l in token_labels],\n            run_time=0.5\n        )\n        self.wait(0.5)\n        \n        # ============================================\n        # PART 3: Show Embedding Vectors (7-11s)\n        # ============================================\n        # Create embedding vectors as rectangles\n        def create_embedding(dims, color, height=2.5):\n            \"\"\"Create a visual representation of an embedding vector.\"\"\"\n            rects = VGroup()\n            rect_height = height / dims\n            for i in range(dims):\n                # Vary color intensity to show different values\n                intensity = 0.3 + 0.7 * (i % 2)\n                rect = Rectangle(\n                    width=0.8,\n                    height=rect_height - 0.02,\n                    fill_opacity=0.8,\n                    fill_color=color,\n                    stroke_width=1,\n                    stroke_color=\"#FFFFFF\"\n                )\n                rects.add(rect)\n            rects.arrange(DOWN, buff=0.02)\n            return rects\n        \n        # Create 3 embedding vectors (6 dimensions each for visualization)\n        dims = 6\n        embeddings = VGroup(\n            create_embedding(dims, \"#4ECDC4\"),\n            create_embedding(dims, \"#4ECDC4\"),\n            create_embedding(dims, \"#4ECDC4\"),\n        ).arrange(RIGHT, buff=1.2).shift(DOWN * 0.5)\n        \n        # Align embeddings with tokens above\n        for i, (emb, token) in enumerate(zip(embeddings, tokens)):\n            emb.move_to([token.get_center()[0], -0.5, 0])\n        \n        embedding_title = Text(\"Token Embeddings\", font_size=18, color=\"#4ECDC4\").next_to(embeddings, DOWN, buff=0.4)\n        \n        embed_arrows = VGroup(*[\n            Arrow(\n                token_labels[i].get_bottom(),\n                emb.get_top(),\n                buff=0.2,\n                stroke_width=2,\n                color=\"#4ECDC4\"\n            ) for i, emb in enumerate(embeddings)\n        ])\n        \n        self.play(\n            FadeIn(embedding_title),\n            *[GrowArrow(a) for a in embed_arrows],\n            run_time=0.8\n        )\n        self.play(\n            *[FadeIn(emb) for emb in embeddings],\n            run_time=1\n        )\n        self.wait(0.7)\n        \n        # ============================================\n        # PART 4: Show Positional Encoding Formula (11-15s)\n        # ============================================\n        # Create positional encoding formula\n        formula = MathTex(\n            r\"PE_{(pos, 2i)} &= \\sin\\left(\\frac{pos}{10000^{2i/d_{model}}}\\right)\",\n            font_size=22,\n            color=\"#FF6B6B\"\n        ).to_edge(LEFT, buff=0.5).shift(DOWN * 2.5)\n        \n        formula2 = MathTex(\n            r\"PE_{(pos, 2i+1)} &= \\cos\\left(\\frac{pos}{10000^{2i/d_{model}}}\\right)\",\n            font_size=22,\n            color=\"#FF6B6B\"\n        ).next_to(formula, DOWN, buff=0.3, aligned_edge=LEFT)\n        \n        formula_group = VGroup(formula, formula2)\n        \n        pe_title = Text(\"Positional Encoding Formula\", font_size=16, color=\"#FF6B6B\").next_to(formula_group, UP, buff=0.3)\n        \n        self.play(\n            FadeIn(pe_title),\n            Write(formula),\n            Write(formula2),\n            run_time=1.5\n        )\n        self.wait(0.5)\n        \n        # ============================================\n        # PART 5: Generate and Show Sinusoidal Signals (15-19s)\n        # ============================================\n        # Create sinusoidal wave visualization\n        axes = Axes(\n            x_range=[0, 4, 1],\n   