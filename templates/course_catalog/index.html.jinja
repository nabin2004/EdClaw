<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Course Catalog — EdClaw</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.6;
      color: #1E1E1E;
      background: #f8f9fa;
    }
    header {
      background: #A51C30;
      color: #fff;
      padding: 2rem 1rem;
      text-align: center;
    }
    header h1 { font-size: 2rem; font-weight: 700; }
    header p { opacity: .85; margin-top: .25rem; }
    main {
      max-width: 960px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    .empty { text-align: center; color: #666; padding: 3rem 0; }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.25rem;
    }
    .card {
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 1px 3px rgba(0,0,0,.1);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      transition: box-shadow .15s;
    }
    .card:hover { box-shadow: 0 4px 12px rgba(0,0,0,.12); }
    .card h2 { font-size: 1.15rem; margin-bottom: .5rem; }
    .card .meta { font-size: .85rem; color: #555; margin-bottom: .75rem; }
    .card .meta span { display: inline-block; margin-right: .75rem; }
    .card .audience { font-size: .9rem; color: #333; flex-grow: 1; }
    .card .link {
      margin-top: 1rem;
      display: inline-block;
      color: #A51C30;
      font-weight: 600;
      text-decoration: none;
    }
    .card .link:hover { text-decoration: underline; }
    footer {
      text-align: center;
      color: #888;
      font-size: .8rem;
      padding: 2rem 1rem;
    }
  </style>
</head>
<body>
  <header>
    <h1>Course Catalog</h1>
    <p>Browse all available courses generated by EdClaw</p>
  </header>
  <main>
    {% if not courses %}
    <p class="empty">No courses registered yet. Generate one with <code>educlaw site generate &lt;series-dir&gt;</code>.</p>
    {% else %}
    <div class="grid">
      {% for c in courses %}
      <div class="card">
        <h2>{{ c.title }}</h2>
        <div class="meta">
          {% if c.semester %}<span>{{ c.semester }}</span>{% endif %}
          {% if c.lecture_count %}<span>{{ c.lecture_count }} lectures</span>{% endif %}
          {% if c.created %}<span>{{ c.created }}</span>{% endif %}
        </div>
        {% if c.audience %}
        <div class="audience">{{ c.audience }}</div>
        {% endif %}
        <a class="link" href="./{{ c.slug }}/">View course &rarr;</a>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </main>
  <footer>
    Generated by <strong>EdClaw</strong> &mdash; local-first educational agent
  </footer>
</body>
</html>
